{
  "name": "covault-tests",
  "version": "1.0.0",
  "description": "Run unit tests on this project.",
  "type": "module",
  "private": true,
  "scripts": {
    "test": "vitest run",
    "test:report": "vitest run -- --coverage --costs",
    "test:watch": "chokidar \"tests/**/*.ts\" \"contracts/**/*.clar\" -c \"npm run test:report\"",
    "fuzz:build": "bash security/build-fuzz.sh",
    "fuzz": "bash security/build-fuzz.sh && rv . covault-core test --runs=1000",
    "fuzz:ci": "bash security/build-fuzz.sh && rv . covault-core test --runs=1000 --seed=424242"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@stacks/clarinet-sdk": "^3.9.0",
    "@stacks/transactions": "^7.2.0",
    "@types/node": "^24.4.0",
    "chokidar-cli": "^3.0.0",
    "vitest": "^4.0.7",
    "vitest-environment-clarinet": "^3.0.0"
  },
  "devDependencies": {
    "@stacks/rendezvous": "^1.0.1"
  }
}

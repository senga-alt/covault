# Covault dApp configuration. Copy to .env.local and adjust as needed.
# All values have sensible defaults for the live testnet deployment.

# Network: testnet | mainnet
VITE_NETWORK=testnet

# covault-core deployment
VITE_CONTRACT_ADDRESS=ST3XC6XFFZQZ6BRYBZRJWRF2Z790TX9GB67KBQW0R
VITE_CONTRACT_NAME=covault-core

# Optional: covault-settler deployment (e.g. ST3XC6....covault-settler).
# When set, settlement becomes permissionless via DIA (settle-from-dia) and the
# manual price entry disappears. When unset, the operator settles manually on core.
# VITE_SETTLER_CONTRACT=

# Absolute origin baked into og:image / twitter:image so link previews work
# (scrapers cannot resolve relative URLs). Usually leave EMPTY: on Vercel the
# origin is auto-detected from the project's production domain and follows it
# when a custom domain is attached. Set explicitly only on non-Vercel hosts,
# e.g. VITE_APP_ORIGIN=https://covault.xyz (no trailing slash).
VITE_APP_ORIGIN=
